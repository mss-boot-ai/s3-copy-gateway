LISTEN_ADDR=:8080

SOURCE_S3_ENDPOINT=https://source-s3.example.com
SOURCE_S3_REGION=us-east-1
SOURCE_S3_ACCESS_KEY=replace-with-source-access-key
SOURCE_S3_SECRET_KEY=replace-with-source-secret-key
SOURCE_S3_PATH_STYLE=true

TARGET_S3_PROVIDER=s3
TARGET_S3_ENDPOINT=https://target-s3.example.com
TARGET_S3_REGION=us-east-1
TARGET_S3_ACCESS_KEY=replace-with-target-access-key
TARGET_S3_SECRET_KEY=replace-with-target-secret-key
TARGET_S3_PATH_STYLE=false

BUCKET_MAPPINGS_JSON={"source-public":"source-storage","destination-public":"destination-storage"}

# Incoming SigV4 authentication defaults to the source credentials.
# S3_ACCESS_KEY=replace-with-client-access-key
# S3_SECRET_KEY=replace-with-client-secret-key
# S3_CREDENTIALS_JSON={"rotating-access-key":"rotating-secret-key"}
AUTH_ACCEPT_REGIONS=*
AUTH_CLOCK_SKEW=5m

S3_ADDRESSING_STYLE=auto
# PUBLIC_S3_BASE_DOMAIN=s3.example.com

MAX_IN_FLIGHT=256
ACQUIRE_WAIT=100ms
SOURCE_CHECK_TIMEOUT=2s
COPY_TIMEOUT=30s

SOURCE_DIAL_TIMEOUT=5s
SOURCE_TLS_HANDSHAKE_TIMEOUT=10s
SOURCE_RESPONSE_HEADER_TIMEOUT=30s
SOURCE_IDLE_CONN_TIMEOUT=90s
SOURCE_REQUEST_CHECKSUM_CALCULATION=WHEN_REQUIRED
SOURCE_RESPONSE_CHECKSUM_VALIDATION=WHEN_REQUIRED

TARGET_DIAL_TIMEOUT=5s
TARGET_TLS_HANDSHAKE_TIMEOUT=10s
TARGET_RESPONSE_HEADER_TIMEOUT=30s
TARGET_IDLE_CONN_TIMEOUT=90s
TARGET_REQUEST_CHECKSUM_CALCULATION=WHEN_REQUIRED
TARGET_RESPONSE_CHECKSUM_VALIDATION=WHEN_REQUIRED
